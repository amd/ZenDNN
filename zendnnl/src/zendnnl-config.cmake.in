@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(OpenMP)

set(ZENDNNL_MSG_PREFIX "(ZENDNNL) ")

# Bake in build-time values of ZENDNNL_DEPENDS_* so consumers see the actual
# configuration ZenDNN was built with, not the source defaults. FORCE so we
# defeat any pre-existing cache value in the consumer's project.
set(ZENDNNL_DEPENDS_AOCLDLP   @ZENDNNL_DEPENDS_AOCLDLP@   CACHE BOOL "" FORCE)
set(ZENDNNL_DEPENDS_ONEDNN    @ZENDNNL_DEPENDS_ONEDNN@    CACHE BOOL "" FORCE)
set(ZENDNNL_DEPENDS_LIBXSMM   @ZENDNNL_DEPENDS_LIBXSMM@   CACHE BOOL "" FORCE)
set(ZENDNNL_DEPENDS_PARLOOPER @ZENDNNL_DEPENDS_PARLOOPER@ CACHE BOOL "" FORCE)
set(ZENDNNL_DEPENDS_FBGEMM    @ZENDNNL_DEPENDS_FBGEMM@    CACHE BOOL "" FORCE)
set(ZENDNNL_DEPENDS_AOCLUTILS ON CACHE BOOL "" FORCE)
set(ZENDNNL_DEPENDS_JSON      ON CACHE BOOL "" FORCE)

set(_TMP_MODULE_PATH "${CMAKE_MODULE_PATH}")
set(CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

include(${CMAKE_CURRENT_LIST_DIR}/ZenDnnlMacros.cmake)
include(${CMAKE_CURRENT_LIST_DIR}/ZenDnnlComponentsOptions.cmake)
include(${CMAKE_CURRENT_LIST_DIR}/ZenDnnlDependenciesOptions.cmake)
include(${CMAKE_CURRENT_LIST_DIR}/ZenDnnlIntegrationOptions.cmake)

find_install_dependencies(${PACKAGE_PREFIX_DIR})

set(CMAKE_MODULE_PATH "${_TMP_MODULE_PATH}")

include(${CMAKE_CURRENT_LIST_DIR}/zendnnl_targets.cmake)
if(ZENDNNL_LIB_BUILD_ARCHIVE)
  check_required_components(zendnnl_archive)
endif()
if(ZENDNNL_LIB_BUILD_SHARED)
  check_required_components(zendnnl)
endif()
